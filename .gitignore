# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# zips built at deploy time (see npm run build)
/private/templates/*.zip

# Only free template sources in git — pro templates stay local
/private/templates/*
!/private/templates/.gitignore
!/private/templates/minimal/
!/private/templates/minimal/**
!/private/templates/ember/
!/private/templates/ember/**
!/private/templates/prism/
!/private/templates/prism/**
!/private/templates/backend/
!/private/templates/backend/**
!/private/templates/portfolio-landing/
!/private/templates/portfolio-landing/**

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
